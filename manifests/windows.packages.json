{
  "fonts": [
    {
      "id": "DEVCOM.JetBrainsMonoNerdFont",
      "source": "winget",
      "legacyScoopPackage": "JetBrainsMono-NF"
    }
  ],
  "powershellModules": [
    {
      "name": "PSReadLine",
      "minVersion": "2.3.0"
    },
    {
      "name": "PSFzf",
      "minVersion": "2.5.0"
    },
    {
      "name": "Terminal-Icons",
      "minVersion": "0.11.0"
    },
    {
      "name": "posh-git",
      "minVersion": "1.1.0"
    }
  ],
  "wingetPackages": [
    {
      "id": "Git.Git",
      "source": "winget",
      "legacyScoopPackage": "git"
    },
    {
      "id": "jdx.mise",
      "source": "winget",
      "legacyScoopPackage": "mise"
    },
    {
      "id": "Microsoft.VisualStudioCode",
      "source": "winget",
      "scope": "user",
      "override": "/VERYSILENT /MERGETASKS=!runcode,addcontextmenufiles,addcontextmenufolders,associatewithfiles,addtopath",
      "legacyScoopPackage": "vscode"
    },
    {
      "id": "MiKTeX.MiKTeX",
      "source": "winget",
      "legacyScoopPackage": "miktex"
    },
    {
      "id": "Microsoft.WindowsTerminal",
      "source": "winget"
    },
    {
      "id": "Microsoft.PowerShell",
      "source": "winget"
    }
  ],
  "vscode": {
    "extensions": [
      "zhuangtongfa.Material-theme",
      "usernamehw.errorlens",
      "eamodio.gitlens",
      "openai.chatgpt",
      "esbenp.prettier-vscode",
      "Gruntfuggly.todo-tree",
      "yoavbls.pretty-ts-errors",
      "pflannery.vscode-versionlens",
      "WallabyJs.console-ninja",
      "pdconsec.vscode-print",
      "dbaeumer.vscode-eslint",
      "code-nature.nilesoft-shell-file-formatter",
      "james-yu.latex-workshop",
      "ltex-plus.vscode-ltex-plus",
      "ms-python.python",
      "charliermarsh.ruff",
      "njpwerner.autodocstring",
      "rust-lang.rust-analyzer",
      "vadimcn.vscode-lldb",
      "fill-labs.dependi",
      "tamasfe.even-better-toml",
      "golang.go",
      "sumneko.lua",
      "ziglang.vscode-zig",
      "llvm-vs-code-extensions.vscode-clangd",
      "ms-vscode.cmake-tools",
      "ms-vscode-remote.vscode-remote-extensionpack",
      "ms-azuretools.vscode-containers",
      "redhat.vscode-yaml",
      "ms-vscode.powershell"
    ]
  }
}
