{{- $name := promptStringOnce . "name" "Git user.name" -}}
{{- $email := promptStringOnce . "email" "Git user.email" -}}
{{- $windowsBootstrapScript := joinPath (env "USERPROFILE") ".local" "share" "chezmoi" "scripts" "bootstrap.ps1" -}}
{{- $wslBootstrapScript := joinPath (env "HOME") ".local" "share" "chezmoi" "scripts" "bootstrap-wsl.sh" -}}
{{- $windowsSshDir := joinPath (env "USERPROFILE") ".ssh" -}}
{{- $windowsGithubKeyName := "github_personal_key" -}}
{{- $windowsGithubKeyPath := joinPath $windowsSshDir $windowsGithubKeyName -}}
{{- $windowsAllowedSignersPath := joinPath $windowsSshDir "allowed_signers" -}}
# Local Chezmoi runtime config (machine-specific)
[data]
    name  = {{ $name | quote }}
    email = {{ $email | quote }}
{{- if eq (env "OS") "Windows_NT" }}
    git_signing_key          = {{ printf "%s.pub" $windowsGithubKeyPath | quote }}
    git_gpg_format           = "ssh"
    git_commit_gpgsign       = true
    git_allowed_signers_file = {{ $windowsAllowedSignersPath | quote }}
    ssh_github_key_name      = {{ $windowsGithubKeyName | quote }}
    ssh_github_key_comment   = {{ $email | quote }}
{{- end }}

[edit]
{{- if eq (env "OS") "Windows_NT" }}
    command = "code.cmd"
{{- else }}
    command = "code"
{{- end }}
    args    = ["--wait"]

[merge]
{{- if eq (env "OS") "Windows_NT" }}
    command = "code.cmd"
{{- else }}
    command = "code"
{{- end }}
    args    = ["--wait", "--merge", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "{{ "{{" }} .Base {{ "}}" }}", "{{ "{{" }} .Destination {{ "}}" }}"]

[diff]
{{- if eq (env "OS") "Windows_NT" }}
    command = "code.cmd"
{{- else }}
    command = "code"
{{- end }}
    args    = ["--wait", "--diff", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Target {{ "}}" }}"]

[git]
    autoCommit = false
    autoPush   = false

[template]
    options = ["missingkey=default"]

{{- if eq (env "OS") "Windows_NT" }}
[hooks.read-source-state.pre]
    command = "powershell.exe"
    args    = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", {{ $windowsBootstrapScript | quote }}, "-FromChezmoiHook"]
{{- else if env "WSL_DISTRO_NAME" }}
[hooks.read-source-state.pre]
    command = "bash"
    args    = [{{ $wslBootstrapScript | quote }}, "--from-chezmoi-hook"]
{{- end }}
