{{- $name := promptStringOnce . "name" "Git user.name" -}}
{{- $email := promptStringOnce . "email" "Git user.email" -}}
{{- $isWindows := eq (env "OS") "Windows_NT" -}}
{{- $isWsl := ne (env "WSL_DISTRO_NAME") "" -}}
{{- $isMacos := eq .chezmoi.os "darwin" -}}
{{- $homeDir := env "HOME" -}}
{{- if $isWindows -}}
{{- $homeDir = env "USERPROFILE" -}}
{{- end -}}
{{- $windowsBootstrapScript := joinPath (env "USERPROFILE") ".local" "share" "chezmoi" "scripts" "bootstrap.ps1" -}}
{{- $wslBootstrapScript := joinPath (env "HOME") ".local" "share" "chezmoi" "scripts" "bootstrap-wsl.sh" -}}
{{- $macosBootstrapScript := joinPath (env "HOME") ".local" "share" "chezmoi" "scripts" "bootstrap-macos.sh" -}}
{{- $sshDir := joinPath $homeDir ".ssh" -}}
{{- $githubKeyName := "github_personal_key" -}}
{{- $githubKeyPath := joinPath $sshDir $githubKeyName -}}
{{- $allowedSignersPath := joinPath $sshDir "allowed_signers" -}}
# Local Chezmoi runtime config (machine-specific)
[data]
    name  = {{ $name | quote }}
    email = {{ $email | quote }}
    github_use_ssh_instead_of_https = false
    git_signing_key          = {{ printf "%s.pub" $githubKeyPath | quote }}
    git_gpg_format           = "ssh"
    git_commit_gpgsign       = true
    git_allowed_signers_file = {{ $allowedSignersPath | quote }}
    ssh_github_key_name      = {{ $githubKeyName | quote }}
    ssh_github_key_comment   = {{ $email | quote }}

[edit]
{{- if $isWindows }}
    command = "code.cmd"
{{- else }}
    command = "code"
{{- end }}
    args    = ["--wait"]

[merge]
{{- if $isWindows }}
    command = "code.cmd"
{{- else }}
    command = "code"
{{- end }}
    args    = ["--wait", "--merge", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "{{ "{{" }} .Base {{ "}}" }}", "{{ "{{" }} .Destination {{ "}}" }}"]

[diff]
{{- if $isWindows }}
    command = "code.cmd"
{{- else }}
    command = "code"
{{- end }}
    args    = ["--wait", "--diff", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Target {{ "}}" }}"]

[git]
    autoCommit = false
    autoPush   = false

[template]
    options = ["missingkey=default"]

{{- if $isWindows }}
[hooks.read-source-state.pre]
    command = "powershell.exe"
    args    = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", {{ $windowsBootstrapScript | quote }}, "-FromChezmoiHook"]
{{- else if $isWsl }}
[hooks.read-source-state.pre]
    command = "bash"
    args    = [{{ $wslBootstrapScript | quote }}, "--from-chezmoi-hook"]
{{- else if $isMacos }}
[hooks.read-source-state.pre]
    command = "bash"
    args    = [{{ $macosBootstrapScript | quote }}, "--from-chezmoi-hook"]
{{- end }}
